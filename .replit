modules = ["nodejs-20"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 5000
externalPort = 80

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 LD_LIBRARY_PATH=\"$REPLIT_LD_LIBRARY_PATH\" bun run src/index.ts"
waitForPort = 5000

[deployment]
deploymentTarget = "autoscale"
run = ["sh", "-c", "LD_LIBRARY_PATH=\"$REPLIT_LD_LIBRARY_PATH\" bun run src/index.ts"]

[userenv]

[userenv.shared]
WALLET_ADDRESS = "0xbDD6f813925F0357fc0D670E31c89F1a451851fa"
WALLET_ADDRESS_BASE = "0xbDD6f813925F0357fc0D670E31c89F1a451851fa"
SOLANA_WALLET_ADDRESS = "BVLVkVKhwd8WCT7ypkztCYenLReGA7sj1SejcieVX9A3"
