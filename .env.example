# ─── YOUR WALLET (where USDC payments arrive) ───
# Solana wallet address (required)
WALLET_ADDRESS=6eUdVwsPArTxwVqEARYGCh4S2qwW2zCs7jSEDRpxydnv
# Base wallet address (optional — defaults to WALLET_ADDRESS if not set)
WALLET_ADDRESS_BASE=0xbDD6f813925F0357fc0D670E31c89F1a451851fa

# ─── SERVICE CONFIG ───
# Google Maps Lead Generator (available at /api/run, /api/details)
SERVICE_NAME=google-maps-lead-generator
SERVICE_DESCRIPTION=Extract structured business data from Google Maps: name, address, phone, website, email, hours, ratings, reviews, categories, and geocoordinates.
PRICE_USDC=0.005

# Mobile SERP Tracker (available at /api/serp)
SERP_SERVICE_NAME=mobile-serp-tracker
SERP_PRICE_USDC=0.003

# Google Reviews & Business Data API (available at /api/reviews/*, /api/business/*)
REVIEWS_PRICE_USDC=0.02
BUSINESS_PRICE_USDC=0.01
SUMMARY_PRICE_USDC=0.005

PORT=3000
RATE_LIMIT=60

# ─── E-COMMERCE PRICE & STOCK MONITOR (POST /api/scrape) ───
# Price per request, charged in USDC on Base. Default: 0.002 USDC (= 2000 base units).
SCRAPE_PRICE_USDC=0.002
# Per-page navigation timeout for the Playwright scraper (milliseconds).
SCRAPE_TIMEOUT_MS=5000
# Optional override for the bundled Chromium binary (Replit/Nix sets this automatically).
# REPLIT_PLAYWRIGHT_CHROMIUM_EXECUTABLE=
# Optional x402 facilitator endpoint (Coinbase commerce facilitator, etc.).
# X402_FACILITATOR_URL=https://x402.coinbase.com

# ─── PROXY CREDENTIALS ───
# Get from https://client.proxies.sx or buy via x402 API:
#   curl https://api.proxies.sx/v1/x402/proxy?country=US&traffic=1
PROXY_HOST=
PROXY_HTTP_PORT=
PROXY_USER=
PROXY_PASS=
PROXY_COUNTRY=US

# ─── OPTIONAL: Custom RPC endpoints ───
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# BASE_RPC_URL=https://mainnet.base.org
